{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "npm run dev",
            "type": "shell",
            "command": "npm run dev",
            "isBackground": true,
            "options": {
                "cwd": "${workspaceFolder}/src/client"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "dedicated"
            },
            "problemMatcher": {
                "pattern": {
                    "regexp": "^$",
                    "file": 1,
                    "line": 2,
                    "message": 3
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "VITE",
                    "endsPattern": "ready in"
                }
            }
        },
        {
            "label": "docker compose up",
            "type": "shell",
            "command": "docker compose -f docker-compose-dev.yml up -d",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "docker compose down",
            "type": "shell",
            "command": "docker compose -f docker-compose-dev.yml down",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "stop npm dev",
            "type": "shell",
            "command": "kill $(lsof -ti:5173) 2>/dev/null; echo 'npm dev stopped'",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            }
        },
        {
            "label": "Prepare Debug",
            "dependsOn": [
				"dotrush: Build",
				"docker compose up",
                "npm run dev"
            ],
            "dependsOrder": "parallel"
        },
        {
            "label": "Cleanup Debug",
            "dependsOn": [
                "stop npm dev",
                "docker compose down"
            ]
        }
    ]
}